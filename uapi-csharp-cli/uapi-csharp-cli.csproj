        </ItemGroup>

        <Message Text="RepackInput = @(RepackInput)" Importance="high" />

        <ILRepack
                OutputType="Exe"
                MainAssembly="$(TargetFileName)"
                OutputAssembly="uapicli.exe"
                InputAssemblies="@(RepackInput)"
                WorkingDirectory="$(TargetDir)" />

        <Message Text="Created single exe: $(TargetDir)$(AssemblyName).single.exe" Importance="high" />

    </Target>

